{
    "access_lists": {
        "EDGE-FEATURES": {
            "entries": {
                "10": {
                    "action": "permit",
                    "line": "permit tcp 192.168.1.0 0.0.0.255 host 10.4.1.1 established log",
                    "parsed": {
                        "destination": {
                            "kind": "host",
                            "value": "10.4.1.1"
                        },
                        "log": true,
                        "protocol": "tcp",
                        "source": {
                            "kind": "network",
                            "value": "192.168.1.0",
                            "wildcard": "0.0.0.255"
                        },
                        "tcp_flags": {
                            "flags": {
                                "established": "include"
                            }
                        }
                    },
                    "sequence": 10
                },
                "20": {
                    "action": "permit",
                    "line": "permit tcp host 10.16.2.2 eq www any precedence network ttl eq 255",
                    "parsed": {
                        "destination": {
                            "kind": "any"
                        },
                        "precedence": "network",
                        "protocol": "tcp",
                        "source": {
                            "kind": "host",
                            "value": "10.16.2.2"
                        },
                        "source_port": {
                            "operator": "eq",
                            "ports": [
                                "www"
                            ]
                        },
                        "ttl": {
                            "operator": "eq",
                            "value": 255
                        }
                    },
                    "sequence": 20
                },
                "30": {
                    "action": "permit",
                    "line": "permit icmp any any router-advertisement time-range GO (inactive)",
                    "parsed": {
                        "destination": {
                            "kind": "any"
                        },
                        "icmp_message": "router-advertisement",
                        "protocol": "icmp",
                        "source": {
                            "kind": "any"
                        },
                        "time_range": {
                            "name": "GO",
                            "status": "inactive"
                        }
                    },
                    "sequence": 30
                },
                "40": {
                    "action": "deny",
                    "line": "deny ip any any tos normal fragments",
                    "parsed": {
                        "destination": {
                            "kind": "any"
                        },
                        "fragments": true,
                        "protocol": "ip",
                        "source": {
                            "kind": "any"
                        },
                        "tos": "normal"
                    },
                    "sequence": 40
                }
            },
            "type": "Extended IP access list"
        }
    }
}
