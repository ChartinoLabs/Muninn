{
  "os": "cisco_ios",
  "command": "show clock",
  "schema": {
    "name": "ShowClockResult",
    "fields": {
      "time": {
        "type": "str",
        "required": true
      },
      "timezone": {
        "type": "str",
        "required": true
      },
      "day_of_week": {
        "type": "str",
        "required": true
      },
      "month": {
        "type": "str",
        "required": true
      },
      "day": {
        "type": "str",
        "required": true
      },
      "year": {
        "type": "str",
        "required": true
      }
    }
  },
  "examples": [
    {
      "name": "Basic clock output with asterisk prefix and UTC timezone",
      "input": "*18:57:38.347 UTC Mon Oct 19 2015\n",
      "expected": {
        "day": "19",
        "day_of_week": "Mon",
        "month": "Oct",
        "time": "18:57:38.347",
        "timezone": "UTC",
        "year": "2015"
      }
    },
    {
      "name": "Clock output with dot prefix indicating time is not authoritative",
      "input": ".18:57:38.347 UTC Mon Oct 19 2015\n",
      "expected": {
        "day": "19",
        "day_of_week": "Mon",
        "month": "Oct",
        "time": "18:57:38.347",
        "timezone": "UTC",
        "year": "2015"
      }
    }
  ]
}
