{
  "os": "cisco_ios",
  "command": "show access-list",
  "schema": {
    "name": "ShowAccessListResult",
    "fields": {
      "access_lists": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "AccessList",
            "fields": {
              "type": {
                "type": "str",
                "required": true
              },
              "entries": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "AccessListEntry",
                    "fields": {
                      "sequence": {
                        "type": "int",
                        "required": true
                      },
                      "action": {
                        "type": "str",
                        "required": true
                      },
                      "line": {
                        "type": "str",
                        "required": true
                      },
                      "parsed": {
                        "type": {
                          "type": "dict",
                          "key": "str",
                          "value": "<class 'object'>"
                        },
                        "required": true
                      },
                      "matches": {
                        "type": "int",
                        "required": false
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
    {
      "name": "Real IOS show access-lists output with host and log entries from Genie",
      "input": "Router# show access-lists 101\nExtended IP access list 101\n    10 permit ip host 10.3.3.3 host 10.5.5.34\n    20 permit icmp any any\n    30 permit ip host 10.34.2.2 host 10.2.54.2\n    40 permit ip host 10.3.4.31 host 10.3.32.3 log\n",
      "expected": {
        "access_lists": {
          "101": {
            "entries": {
              "10": {
                "action": "permit",
                "line": "permit ip host 10.3.3.3 host 10.5.5.34",
                "parsed": {
                  "destination": {
                    "kind": "host",
                    "value": "10.5.5.34"
                  },
                  "protocol": "ip",
                  "source": {
                    "kind": "host",
                    "value": "10.3.3.3"
                  }
                },
                "sequence": 10
              },
              "20": {
                "action": "permit",
                "line": "permit icmp any any",
                "parsed": {
                  "destination": {
                    "kind": "any"
                  },
                  "protocol": "icmp",
                  "source": {
                    "kind": "any"
                  }
                },
                "sequence": 20
              },
              "30": {
                "action": "permit",
                "line": "permit ip host 10.34.2.2 host 10.2.54.2",
                "parsed": {
                  "destination": {
                    "kind": "host",
                    "value": "10.2.54.2"
                  },
                  "protocol": "ip",
                  "source": {
                    "kind": "host",
                    "value": "10.34.2.2"
                  }
                },
                "sequence": 30
              },
              "40": {
                "action": "permit",
                "line": "permit ip host 10.3.4.31 host 10.3.32.3 log",
                "parsed": {
                  "destination": {
                    "kind": "host",
                    "value": "10.3.32.3"
                  },
                  "log": true,
                  "protocol": "ip",
                  "source": {
                    "kind": "host",
                    "value": "10.3.4.31"
                  }
                },
                "sequence": 40
              }
            },
            "type": "Extended IP access list"
          }
        }
      }
    },
    {
      "name": "Real IOS-XE show access-lists output with standard ACL matches from Genie",
      "input": "show access-lists\nStandard IP access list 1\n    10 deny   10.9.3.4 log (18 matches)\n    20 permit any (58 matches)\nExtended IP access list meraki-fqdn-dns\nntc-pod19-csrv#\n",
      "expected": {
        "access_lists": {
          "1": {
            "entries": {
              "10": {
                "action": "deny",
                "line": "deny 10.9.3.4 log",
                "matches": 18,
                "parsed": {
                  "log": true,
                  "source": {
                    "kind": "address",
                    "value": "10.9.3.4"
                  }
                },
                "sequence": 10
              },
              "20": {
                "action": "permit",
                "line": "permit any",
                "matches": 58,
                "parsed": {
                  "source": {
                    "kind": "any"
                  }
                },
                "sequence": 20
              }
            },
            "type": "Standard IP access list"
          },
          "meraki-fqdn-dns": {
            "entries": {},
            "type": "Extended IP access list"
          }
        }
      }
    },
    {
      "name": "Real IOS-XE show access-lists output with dscp, established, precedence, ttl, and port ranges from Genie",
      "input": "Extended IP access list acl_name\n    10 permit ip any any (10031 matches)\nExtended IP access list ipv4_acl\n    10 permit tcp any any eq www\n    20 permit tcp any any eq 22\nExtended IP access list test1\n    10 permit pim any any dscp default option 222 log\n    20 permit icmp 0.1.1.1 255.0.0.0 any 10 66\nExtended IP access list test22\n    10 permit tcp 192.168.1.0 0.0.0.255 host 10.4.1.1 established log\n    20 permit tcp host 10.16.2.2 eq www telnet 443 any precedence network ttl eq 255\n    30 deny ip any any\n    40 permit tcp any range ftp-data bgp any\nExtended IP access list test33\n    10 permit icmp any 10.120.194.64 0.0.0.63\n    20 permit tcp any eq 443 10.120.194.64 0.0.0.63\nIPv6 access list ipv6_acl\n    permit ipv6 host 2001::1 host 2001:1::2 sequence 20\n    permit tcp any eq www 8443 host 2001:2::2 sequence 30\n    permit ipv6 2001:db8:9:9::3 2001:db8:10:10::4 2001:db8:1:1::1 2001:db8:24:24::6 log sequence 80\nIPv6 access list preauth_v6 (per-user)\n    permit udp any any eq domain sequence 10\n    permit esp any any dscp cs7 log sequence 20\n    deny ipv6 any any sequence 30\nExtended MAC access list mac_acl\n    permit any any\n    deny   any any msdos\n    deny   any any vlan 10\n    permit host 0001.00ff.0235 host 0003.00ff.0306 lsap 0x1 0xD8FE\n    permit any any aarp cos 4 vlan 20\n",
      "expected": {
        "access_lists": {
          "acl_name": {
            "entries": {
              "10": {
                "action": "permit",
                "line": "permit ip any any",
                "matches": 10031,
                "parsed": {
                  "destination": {
                    "kind": "any"
                  },
                  "protocol": "ip",
                  "source": {
                    "kind": "any"
                  }
                },
                "sequence": 10
              }
            },
            "type": "Extended IP access list"
          },
          "ipv4_acl": {
            "entries": {
              "10": {
                "action": "permit",
                "line": "permit tcp any any eq www",
                "parsed": {
                  "destination": {
                    "kind": "any"
                  },
                  "destination_port": {
                    "operator": "eq",
                    "ports": [
                      "www"
                    ]
                  },
                  "protocol": "tcp",
                  "source": {
                    "kind": "any"
                  }
                },
                "sequence": 10
              },
              "20": {
                "action": "permit",
                "line": "permit tcp any any eq 22",
                "parsed": {
                  "destination": {
                    "kind": "any"
                  },
                  "destination_port": {
                    "operator": "eq",
                    "ports": [
                      "22"
                    ]
                  },
                  "protocol": "tcp",
                  "source": {
                    "kind": "any"
                  }
                },
                "sequence": 20
              }
            },
            "type": "Extended IP access list"
          },
          "test1": {
            "entries": {
              "10": {
                "action": "permit",
                "line": "permit pim any any dscp default option 222 log",
                "parsed": {
                  "destination": {
                    "kind": "any"
                  },
                  "dscp": "default",
                  "extra": [
                    "option",
                    "222"
                  ],
                  "log": true,
                  "protocol": "pim",
                  "source": {
                    "kind": "any"
                  }
                },
                "sequence": 10
              },
              "20": {
                "action": "permit",
                "line": "permit icmp 0.1.1.1 255.0.0.0 any 10 66",
                "parsed": {
                  "destination": {
                    "kind": "any"
                  },
                  "extra": [
                    "10",
                    "66"
                  ],
                  "protocol": "icmp",
                  "source": {
                    "kind": "network",
                    "value": "0.1.1.1",
                    "wildcard": "255.0.0.0"
                  }
                },
                "sequence": 20
              }
            },
            "type": "Extended IP access list"
          },
          "test22": {
            "entries": {
              "10": {
                "action": "permit",
                "line": "permit tcp 192.168.1.0 0.0.0.255 host 10.4.1.1 established log",
                "parsed": {
                  "destination": {
                    "kind": "host",
                    "value": "10.4.1.1"
                  },
                  "log": true,
                  "protocol": "tcp",
                  "source": {
                    "kind": "network",
                    "value": "192.168.1.0",
                    "wildcard": "0.0.0.255"
                  },
                  "tcp_flags": {
                    "flags": {
                      "established": "include"
                    }
                  }
                },
                "sequence": 10
              },
              "20": {
                "action": "permit",
                "line": "permit tcp host 10.16.2.2 eq www telnet 443 any precedence network ttl eq 255",
                "parsed": {
                  "destination": {
                    "kind": "address",
                    "value": "telnet"
                  },
                  "extra": [
                    "443",
                    "any"
                  ],
                  "precedence": "network",
                  "protocol": "tcp",
                  "source": {
                    "kind": "host",
                    "value": "10.16.2.2"
                  },
                  "source_port": {
                    "operator": "eq",
                    "ports": [
                      "www"
                    ]
                  },
                  "ttl": {
                    "operator": "eq",
                    "value": 255
                  }
                },
                "sequence": 20
              },
              "30": {
                "action": "deny",
                "line": "deny ip any any",
                "parsed": {
                  "destination": {
                    "kind": "any"
                  },
                  "protocol": "ip",
                  "source": {
                    "kind": "any"
                  }
                },
                "sequence": 30
              },
              "40": {
                "action": "permit",
                "line": "permit tcp any range ftp-data bgp any",
                "parsed": {
                  "destination": {
                    "kind": "any"
                  },
                  "protocol": "tcp",
                  "source": {
                    "kind": "any"
                  },
                  "source_port": {
                    "operator": "range",
                    "ports": [
                      "ftp-data",
                      "bgp"
                    ]
                  }
                },
                "sequence": 40
              }
            },
            "type": "Extended IP access list"
          },
          "test33": {
            "entries": {
              "10": {
                "action": "permit",
                "line": "permit icmp any 10.120.194.64 0.0.0.63",
                "parsed": {
                  "destination": {
                    "kind": "network",
                    "value": "10.120.194.64",
                    "wildcard": "0.0.0.63"
                  },
                  "protocol": "icmp",
                  "source": {
                    "kind": "any"
                  }
                },
                "sequence": 10
              },
              "20": {
                "action": "permit",
                "line": "permit tcp any eq 443 10.120.194.64 0.0.0.63",
                "parsed": {
                  "destination": {
                    "kind": "network",
                    "value": "10.120.194.64",
                    "wildcard": "0.0.0.63"
                  },
                  "protocol": "tcp",
                  "source": {
                    "kind": "any"
                  },
                  "source_port": {
                    "operator": "eq",
                    "ports": [
                      "443"
                    ]
                  }
                },
                "sequence": 20
              }
            },
            "type": "Extended IP access list"
          }
        }
      }
    },
    {
