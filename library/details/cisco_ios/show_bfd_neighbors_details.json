            "GigabitEthernet0/0/1": {
              "local_address": "10.1.1.1",
              "neighbor_address": "10.1.1.2",
              "interface": "GigabitEthernet0/0/1",
              "state": "UP",
              "ld_rd": "4097/4097",
              "rh_rs": "Up",
              "echo_tx_interval_ms": 50,
              "timers": {
                "tx_interval_ms": 50000,
                "rx_interval_ms": 50000,
                "multiplier": 3
              },
              "holddown_ms": 150,
              "rx_count": 1234,
              "tx_count": 1230,
              "round_trip_timer_ms": 2,
              "registered_protocols": [
                "OSPF",
                "BGP"
              ],
              "uptime": "01:23:45",
              "last_packet_received_ms": 12
            }
          },
          "10.2.2.2": {
            "GigabitEthernet0/0/2": {
              "local_address": "10.2.2.1",
              "neighbor_address": "10.2.2.2",
              "interface": "GigabitEthernet0/0/2",
              "state": "UP",
              "ld_rd": "4098/4098",
              "rh_rs": "Up",
              "echo_tx_interval_ms": 100,
              "timers": {
                "tx_interval_ms": 100000,
                "rx_interval_ms": 100000,
                "multiplier": 5
              },
              "holddown_ms": 500,
              "rx_count": 5678,
              "tx_count": 5670,
              "round_trip_timer_ms": 5,
              "registered_protocols": [
                "EIGRP"
              ],
              "uptime": "02:34:56",
              "last_packet_received_ms": 45
            }
          }
        }
      }
    }
  ]
}
