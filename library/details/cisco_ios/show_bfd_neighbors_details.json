{
  "os": "cisco_ios",
  "command": "show bfd neighbors details",
  "schema": {
    "name": "ShowBfdNeighborsDetailsResult",
    "fields": {
      "neighbors": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "BfdSessionEntry",
              "fields": {
                "local_address": {
                  "type": "str",
                  "required": true
                },
                "neighbor_address": {
                  "type": "str",
                  "required": true
                },
                "interface": {
                  "type": "str",
                  "required": true
                },
                "state": {
                  "type": "str",
                  "required": true
                },
                "session_type": {
                  "type": "str",
                  "required": false
                },
                "ld_rd": {
                  "type": "str",
                  "required": false
                },
                "rh_rs": {
                  "type": "str",
                  "required": false
                },
                "holddown_ms": {
                  "type": "int",
                  "required": false
                },
                "timers": {
                  "type": {
                    "name": "BfdTimers",
                    "fields": {
                      "tx_interval_ms": {
                        "type": "int",
                        "required": true
                      },
                      "rx_interval_ms": {
                        "type": "int",
                        "required": true
                      },
                      "multiplier": {
                        "type": "int",
                        "required": true
                      }
                    }
                  },
                  "required": false
                },
                "registered_protocols": {
                  "type": {
                    "type": "list",
                    "items": "str"
                  },
                  "required": false
                },
                "uptime": {
                  "type": "str",
                  "required": false
                },
                "last_packet_received_ms": {
                  "type": "int",
                  "required": false
                },
                "rx_count": {
                  "type": "int",
                  "required": false
                },
                "tx_count": {
                  "type": "int",
                  "required": false
                },
                "round_trip_timer_ms": {
                  "type": "int",
                  "required": false
                },
                "echo_tx_interval_ms": {
                  "type": "int",
                  "required": false
                }
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
    {
