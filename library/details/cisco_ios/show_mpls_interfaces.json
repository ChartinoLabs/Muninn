{
  "os": "cisco_ios",
  "command": "show mpls interfaces",
  "schema": {
    "name": "ShowMplsInterfacesResult",
    "fields": {
      "interfaces": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "MplsInterfaceEntry",
            "fields": {
              "ip_enabled": {
                "type": "bool",
                "required": true
              },
              "ip_protocol": {
                "type": "str",
                "required": false
              },
              "tunnel": {
                "type": "bool",
                "required": true
              },
              "bgp": {
                "type": "bool",
                "required": true
              },
              "static": {
                "type": "bool",
                "required": true
              },
              "operational": {
                "type": "bool",
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
    {
