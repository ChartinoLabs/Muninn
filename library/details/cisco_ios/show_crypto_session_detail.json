                        "type": "int",
                        "required": false
                      },
                      "pkts_digest": {
                        "type": "int",
                        "required": false
                      },
                      "pkts_decaps": {
                        "type": "int",
                        "required": false
                      },
                      "pkts_decrypt": {
                        "type": "int",
                        "required": false
                      },
                      "pkts_verify": {
