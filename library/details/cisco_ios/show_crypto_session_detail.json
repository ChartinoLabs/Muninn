                        "required": false
                      },
                      "remote_crypto_endpt": {
                        "type": "str",
                        "required": false
                      },
                      "path_mtu": {
                        "type": "int",
                        "required": false
                      },
                      "ip_mtu": {
                        "type": "int",
                        "required": false
