{
  "os": "cisco_ios",
  "command": "show platform",
  "schema": {
    "name": "ShowPlatformResult",
    "fields": {
      "chassis_type": {
        "type": "str",
        "required": false
      },
      "slots": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "SlotEntry",
            "fields": {
              "state": {
                "type": "str",
                "required": false
              },
              "type": {
                "type": "str",
                "required": false
              },
              "insert_time": {
                "type": "str",
                "required": false
              },
              "cpld_version": {
                "type": "str",
                "required": false
              },
              "firmware_version": {
                "type": "str",
                "required": false
              },
              "subslots": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "SubslotEntry",
                    "fields": {
                      "type": {
                        "type": "str",
                        "required": true
                      },
                      "state": {
                        "type": "str",
                        "required": false
                      },
                      "insert_time": {
                        "type": "str",
                        "required": true
                      }
                    }
                  }
                },
                "required": false
              }
            }
          }
        },
        "required": false
      },
      "switches": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "SwitchEntry",
            "fields": {
              "ports": {
                "type": "int",
                "required": true
              },
              "model": {
                "type": "str",
                "required": true
              },
              "serial_no": {
                "type": "str",
                "required": true
              },
              "mac_address": {
                "type": "str",
                "required": true
              },
              "hw_version": {
                "type": "str",
                "required": true
              },
              "sw_version": {
                "type": "str",
                "required": true
              }
            }
          }
        },
        "required": false
      },
      "stack": {
        "type": {
          "name": "StackInfo",
          "fields": {
            "mac_address": {
              "type": "str",
              "required": false
            },
            "mac_persistency_wait_time": {
              "type": "str",
              "required": false
            },
            "members": {
              "type": {
                "type": "dict",
                "key": "str",
                "value": {
                  "name": "StackMemberEntry",
                  "fields": {
                    "role": {
                      "type": "str",
                      "required": true
                    },
                    "priority": {
                      "type": "int",
                      "required": true
                    },
                    "state": {
                      "type": "str",
                      "required": true
                    }
                  }
                }
              },
              "required": true
            }
          }
        },
        "required": false
      }
    }
  },
