        "vtp_version_capable": "1 to 3",
        "vtp_version_running": 1,
        "domain_name": "router_vtp",
        "pruning_mode": "Disabled",
        "traps_generation": "Disabled",
        "device_id": "e05f.dead.beef",
        "last_modified_by": "10.0.0.1",
        "last_modified_at": "6-12-15 14:06:57",
        "local_updater_id": "10.1.1.1",
        "local_updater_interface": "Vl1",
        "operating_mode": "Server",
        "max_vlans": 1005,
        "existing_vlans": 20,
        "configuration_revision": 38,
        "md5_digest": "0xFF 0xFF 0xFF 0xFF 0xFF 0xFF 0xFF 0xFF 0x89 0x07 0xE4 0x53 0xBA 0xB1 0x1C 0xC1"
