{
  "os": "cisco_ios",
  "command": "show module submodule",
  "schema": {
    "name": "ShowModuleSubmoduleResult",
    "fields": {
      "submodules": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "SubmoduleDetails",
              "fields": {
                "model": {
                  "type": "str",
                  "required": true
                },
                "serial": {
                  "type": "str",
                  "required": true
                },
                "hw_ver": {
                  "type": "str",
                  "required": true
                },
                "status": {
                  "type": "str",
                  "required": true
                }
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
