{
  "os": "cisco_ios",
  "command": "show ip eigrp topology",
  "schema": {
    "name": "ShowIpEigrpTopologyResult",
    "fields": {
      "autonomous_systems": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "AutonomousSystemEntry",
            "fields": {
              "as_number": {
                "type": "int",
                "required": true
              },
              "router_id": {
                "type": "str",
                "required": true
              },
              "routes": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "TopologyEntry",
                    "fields": {
                      "code": {
                        "type": "str",
                        "required": true
                      },
                      "successor_count": {
                        "type": "int",
                        "required": true
                      },
                      "feasible_distance": {
                        "type": "int",
                        "required": false
                      },
                      "tag": {
                        "type": "int",
                        "required": false
                      },
                      "paths": {
                        "type": {
                          "type": "list",
                          "items": {
                            "name": "PathEntry",
                            "fields": {
                              "next_hop": {
                                "type": "str",
                                "required": true
                              },
                              "interface": {
                                "type": "str",
                                "required": false
                              },
                              "reported_distance": {
                                "type": "int",
                                "required": false
                              }
                            }
                          }
                        },
                        "required": true
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
