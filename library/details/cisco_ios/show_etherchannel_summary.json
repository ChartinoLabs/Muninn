{
  "os": "cisco_ios",
  "command": "show etherchannel summary",
  "schema": {
    "name": "ShowEtherchannelSummaryResult",
    "fields": {
      "num_channel_groups": {
        "type": "int",
        "required": true
      },
      "num_aggregators": {
        "type": "int",
        "required": true
      },
      "port_channels": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "PortChannelEntry",
            "fields": {
              "port_channel": {
                "type": "str",
                "required": true
              },
              "port_channel_status": {
                "type": "str",
                "required": true
              },
              "layer": {
                "type": "str",
                "required": true
              },
              "protocol": {
                "type": "str",
                "required": false
              },
              "members": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "MemberPort",
                    "fields": {
                      "status": {
                        "type": "str",
                        "required": true
                      },
                      "interface": {
                        "type": "str",
                        "required": true
                      }
                    }
                  }
                },
                "required": false
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
