{
  "os": "cisco_ios",
  "command": "show archive",
  "schema": {
    "name": "ShowArchiveResult",
    "fields": {
      "max_archive_count": {
        "type": "int",
        "required": false
      },
      "current_count": {
        "type": "int",
        "required": false
      },
      "next_filename": {
        "type": "str",
        "required": false
      },
      "entries": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "ArchiveEntry",
            "fields": {
              "number": {
                "type": "int",
                "required": true
              },
              "filename": {
                "type": "str",
                "required": true
              },
              "most_recent": {
                "type": "bool",
                "required": false
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
