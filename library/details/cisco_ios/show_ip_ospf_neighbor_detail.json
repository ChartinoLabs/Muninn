{
  "os": "cisco_ios",
  "command": "show ip ospf neighbor detail",
  "schema": {
    "name": "ShowIpOspfNeighborDetailResult",
    "fields": {
      "neighbors": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "InterfaceNeighborEntry",
              "fields": {
                "interface_address": {
                  "type": "str",
                  "required": true
                },
                "area": {
                  "type": "str",
                  "required": true
                },
                "interface": {
                  "type": "str",
                  "required": true
                },
                "priority": {
                  "type": "int",
                  "required": true
                },
                "state": {
                  "type": "str",
                  "required": true
                },
                "state_changes": {
                  "type": "int",
                  "required": true
                },
                "dr": {
                  "type": "str",
                  "required": true
                },
                "bdr": {
                  "type": "str",
                  "required": true
                },
                "dead_timer": {
                  "type": "str",
                  "required": true
                },
                "uptime": {
                  "type": "str",
                  "required": true
                },
                "retransmission_queue_length": {
                  "type": "int",
                  "required": true
                },
                "retransmission_count": {
                  "type": "int",
                  "required": true
                },
                "retransmission_stats": {
                  "type": {
                    "name": "RetransmissionStats",
                    "fields": {
                      "last_scan_length": {
                        "type": "int",
                        "required": true
                      },
                      "max_scan_length": {
                        "type": "int",
                        "required": true
                      },
                      "last_scan_time_msec": {
                        "type": "int",
                        "required": true
                      },
                      "max_scan_time_msec": {
                        "type": "int",
                        "required": true
                      }
                    }
                  },
                  "required": true
                },
                "interface_id": {
                  "type": "int",
                  "required": false
                },
                "sr_adj_label": {
                  "type": "int",
                  "required": false
                },
                "hello_options": {
                  "type": "str",
                  "required": false
                },
                "dbd_options": {
                  "type": "str",
                  "required": false
                },
                "lls_options": {
                  "type": "str",
                  "required": false
                }
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
