{
  "os": "cisco_ios",
  "command": "show ip ospf database",
  "schema": {
    "name": "ShowIpOspfDatabaseResult",
    "fields": {
      "processes": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "ProcessEntry",
            "fields": {
              "router_id": {
                "type": "str",
                "required": true
              },
              "sections": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "type": "list",
                    "items": {
                      "name": "LsaTypeSection",
                      "fields": {
                        "area": {
                          "type": "str",
                          "required": false
                        },
                        "lsas": {
                          "type": {
                            "type": "dict",
                            "key": "str",
                            "value": {
                              "type": "dict",
                              "key": "str",
                              "value": {
                                "name": "LsaEntry",
                                "fields": {
                                  "adv_router": {
                                    "type": "str",
                                    "required": true
                                  },
                                  "age": {
                                    "type": "int",
                                    "required": true
                                  },
                                  "seq": {
                                    "type": "str",
                                    "required": true
                                  },
                                  "checksum": {
                                    "type": "str",
                                    "required": true
                                  },
                                  "link_count": {
                                    "type": "int",
                                    "required": false
                                  },
                                  "tag": {
                                    "type": "int",
                                    "required": false
                                  }
                                }
                              }
                            }
                          },
                          "required": true
                        }
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
