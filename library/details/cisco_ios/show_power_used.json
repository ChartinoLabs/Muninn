{
  "os": "cisco_ios",
  "command": "show power used",
  "schema": {
    "name": "ShowPowerUsedResult",
    "fields": {
      "watts": {
        "type": "float",
        "required": true
      },
      "amps": {
        "type": "float",
        "required": true
      },
      "volts": {
        "type": "int",
        "required": true
      }
    }
  },
  "examples": [
    {
      "name": "Standard power usage output with typical values",
      "input": "system power used =      2255.76 Watts (43.38 Amps @ 52V)\n",
      "expected": {
        "amps": 43.38,
        "volts": 52,
        "watts": 2255.76
      }
    },
    {
      "name": "Low power usage with smaller values",
      "input": "system power used =      120.50 Watts (5.02 Amps @ 24V)\n",
      "expected": {
        "amps": 5.02,
        "volts": 24,
        "watts": 120.5
      }
    }
  ]
}
