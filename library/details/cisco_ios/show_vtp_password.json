{
  "os": "cisco_ios",
  "command": "show vtp password",
  "schema": {
    "name": "ShowVtpPasswordResult",
    "fields": {
      "vtp": {
        "type": {
          "name": "VtpStatus",
          "fields": {
            "configured": {
              "type": "bool",
              "required": true
            },
            "password": {
              "type": "str",
              "required": false
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
    {
      "name": "Show vtp password output when password is not configured",
      "input": "The VTP password is not configured.\n",
      "expected": {
        "vtp": {
          "configured": false
        }
      }
    },
    {
      "name": "Show vtp password output when password is configured",
      "input": "VTP Password: testing\n",
      "expected": {
        "vtp": {
          "configured": true,
          "password": "testing"
        }
      }
    }
  ]
}
