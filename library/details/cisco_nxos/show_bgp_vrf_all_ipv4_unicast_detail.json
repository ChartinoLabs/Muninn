{
  "os": "cisco_nxos",
  "command": "show bgp vrf all ipv4 unicast detail",
  "schema": {
    "name": "ShowBgpVrfAllIpv4UnicastDetailResult",
    "fields": {
      "vrfs": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "VrfEntry",
            "fields": {
              "router_id": {
                "type": "str",
                "required": true
              },
              "local_as": {
                "type": "int",
                "required": true
              },
              "prefixes": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "PrefixEntry",
                    "fields": {
                      "version": {
                        "type": "int",
                        "required": true
                      },
                      "paths": {
                        "type": {
                          "type": "dict",
                          "key": "str",
                          "value": {
                            "name": "PathEntry",
                            "fields": {
                              "next_hop": {
                                "type": "str",
                                "required": true
                              },
                              "metric": {
                                "type": "int",
                                "required": false
                              },
                              "local_preference": {
                                "type": "int",
                                "required": false
                              },
                              "weight": {
                                "type": "int",
                                "required": true
                              },
                              "origin": {
                                "type": "str",
                                "required": true
                              },
                              "as_path": {
                                "type": "str",
                                "required": false
                              },
                              "communities": {
                                "type": "str",
                                "required": false
                              },
                              "extended_communities": {
                                "type": "str",
                                "required": false
                              },
                              "originator_id": {
                                "type": "str",
                                "required": false
                              },
                              "cluster_list": {
                                "type": "str",
                                "required": false
                              },
                              "peer_id": {
                                "type": "str",
                                "required": false
                              },
                              "source_id": {
                                "type": "str",
                                "required": false
                              },
                              "status": {
                                "type": "str",
                                "required": true
                              },
                              "best_path": {
                                "type": "bool",
                                "required": true
                              },
                              "multipath": {
                                "type": "bool",
                                "required": false
                              }
                            }
                          }
                        },
                        "required": true
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
