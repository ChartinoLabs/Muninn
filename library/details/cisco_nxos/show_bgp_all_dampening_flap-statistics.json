                                "peer": {
                                  "type": "str",
                                  "required": true
                                },
                                "flaps": {
                                  "type": "int",
                                  "required": true
                                },
                                "duration": {
                                  "type": "str",
                                  "required": true
                                },
                                "reuse": {
                                  "type": "str",
                                  "required": true
                                },
                                "path": {
                                  "type": "str",
                                  "required": true
                                }
                              }
                            }
                          }
                        },
                        "required": true
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
