                        "igp_cost": {
                          "type": "int",
                          "required": true
                        },
                        "igp_route_type": {
                          "type": "int",
                          "required": true
                        },
                        "igp_preference": {
                          "type": "int",
                          "required": true
                        },
                        "attached": {
                          "type": "bool",
                          "required": true
                        },
                        "local": {
                          "type": "bool",
                          "required": true
                        },
                        "reachable": {
                          "type": "bool",
                          "required": true
                        },
                        "labeled": {
                          "type": "bool",
                          "required": true
                        },
                        "filtered": {
                          "type": "bool",
                          "required": true
                        },
                        "pending_update": {
                          "type": "bool",
                          "required": true
                        },
                        "resolve_time": {
                          "type": "str",
                          "required": true
                        },
                        "rib_route": {
                          "type": "str",
                          "required": true
                        },
                        "metric_next_advertise": {
                          "type": "str",
                          "required": true
                        },
                        "rnh_epoch": {
                          "type": "int",
                          "required": true
                        },
                        "attached_nexthops": {
                          "type": {
                            "type": "dict",
                            "key": "str",
                            "value": {
                              "name": "AttachedNexthopEntry",
                              "fields": {
                                "interface": {
                                  "type": "str",
                                  "required": true
                                }
                              }
                            }
                          },
                          "required": true
                        }
                      }
                    }
                  },
                  "required": true
                }
              }
            }
          }
        },
        "required": true
      }
    }
