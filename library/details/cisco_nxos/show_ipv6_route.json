{
  "os": "cisco_nxos",
  "command": "show ipv6 route",
  "schema": {
    "name": "ShowIpv6RouteResult",
    "fields": {
      "vrfs": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "VrfRoutes",
            "fields": {
              "routes": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "RouteEntry",
                    "fields": {
                      "ubest": {
                        "type": "int",
                        "required": true
                      },
                      "mbest": {
                        "type": "int",
                        "required": true
                      },
                      "attached": {
                        "type": "bool",
                        "required": false
                      },
                      "next_hops": {
                        "type": {
                          "type": "list",
                          "items": {
                            "name": "NextHop",
                            "fields": {
                              "next_hop": {
                                "type": "str",
                                "required": true
                              },
                              "interface": {
                                "type": "str",
                                "required": false
                              },
                              "preference": {
                                "type": "int",
                                "required": true
                              },
                              "metric": {
                                "type": "int",
                                "required": true
                              },
                              "uptime": {
                                "type": "str",
                                "required": true
                              },
                              "protocol": {
                                "type": "str",
                                "required": true
                              },
                              "best": {
                                "type": "bool",
                                "required": false
                              },
                              "tag": {
                                "type": "int",
                                "required": false
                              },
                              "route_type": {
                                "type": "str",
                                "required": false
                              },
                              "segid": {
                                "type": "int",
                                "required": false
                              },
                              "tunnelid": {
                                "type": "str",
                                "required": false
                              },
                              "encap": {
                                "type": "str",
                                "required": false
                              }
                            }
                          }
                        },
                        "required": true
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
