{
  "os": "cisco_nxos",
  "command": "show vpc",
  "schema": {
    "name": "ShowVpcResult",
    "fields": {
      "domain_id": {
        "type": "int",
        "required": true
      },
      "peer_status": {
        "type": "str",
        "required": true
      },
      "keepalive_status": {
        "type": "str",
        "required": true
      },
      "configuration_consistency_status": {
        "type": "str",
        "required": true
      },
      "per_vlan_consistency_status": {
        "type": "str",
        "required": true
      },
      "vpc_role": {
        "type": "str",
        "required": true
      },
      "number_of_vpcs": {
        "type": "int",
        "required": true
      },
      "peer_gateway": {
        "type": "str",
        "required": true
      },
      "dual_active_excluded_vlans": {
        "type": "str",
        "required": false
      },
      "graceful_consistency_check": {
        "type": "str",
        "required": true
      },
      "auto_recovery_status": {
        "type": "str",
        "required": true
      },
      "delay_restore_status": {
        "type": "str",
        "required": true
      },
      "delay_restore_svi_status": {
        "type": "str",
        "required": true
      },
      "configuration_inconsistency_reason": {
        "type": "str",
        "required": false
      },
      "type_2_inconsistency_reason": {
        "type": "str",
        "required": false
      },
      "operational_layer3_peer_router": {
        "type": "str",
        "required": false
      },
      "peer_links": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "PeerLinkEntry",
            "fields": {
              "port": {
                "type": "str",
                "required": true
              },
              "status": {
                "type": "str",
                "required": true
              },
              "active_vlans": {
                "type": "str",
                "required": false
              }
            }
          }
        },
        "required": false
      }
    }
  },
  "examples": [
    {
      "name": "Basic vPC status with peer-link information",
      "input": "Legend:\n                (*) - local vPC is down, forwarding via vPC peer-link\n\nvPC domain id                     : 100\nPeer status                       : peer link is down\nvPC keep-alive status             : Suspended (Destination IP not reachable)\nConfiguration consistency status  : failed\nPer-vlan consistency status       : success\nConfiguration inconsistency reason: Consistency Check Not Performed\nType-2 inconsistency reason       : Consistency Check Not Performed\nvPC role                          : none established\nNumber of vPCs configured         : 0\nPeer Gateway                      : Disabled\nDual-active excluded VLANs        : -\nGraceful Consistency Check        : Disabled (due to peer configuration)\nAuto-recovery status              : Disabled\nDelay-restore status              : Timer is off.(timeout = 30s)\nDelay-restore SVI status          : Timer is off.(timeout = 10s)\n\nvPC Peer-link status\n---------------------------------------------------------------------\nid   Port   Status Active vlans\n--   ----   ------ --------------------------------------------------\n1    Po12   down   -\n2    Po13   up     10\n",
      "expected": {
        "domain_id": 100,
        "peer_status": "peer link is down",
        "keepalive_status": "Suspended (Destination IP not reachable)",
        "configuration_consistency_status": "failed",
        "per_vlan_consistency_status": "success",
        "vpc_role": "none established",
        "number_of_vpcs": 0,
        "peer_gateway": "Disabled",
        "graceful_consistency_check": "Disabled (due to peer configuration)",
        "auto_recovery_status": "Disabled",
        "delay_restore_status": "Timer is off.(timeout = 30s)",
        "delay_restore_svi_status": "Timer is off.(timeout = 10s)",
        "configuration_inconsistency_reason": "Consistency Check Not Performed",
        "type_2_inconsistency_reason": "Consistency Check Not Performed",
        "peer_links": {
          "1": {
            "port": "Port-channel12",
            "status": "down"
          },
          "2": {
            "port": "Port-channel13",
            "status": "up",
            "active_vlans": "10"
          }
        }
      }
    }
  ]
}
