{
  "os": "cisco_nxos",
  "command": "show mac address-table",
  "schema": {
    "name": "ShowMacAddressTableResult",
    "fields": {
      "mac_table": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "MacTableRow",
              "fields": {
                "kind": {
                  "type": {
                    "type": "literal",
