                "port": {
                  "type": "str",
                  "required": false
                },
                "is_routed": {
                  "type": "bool",
                  "required": false
                },
                "age": {
                  "type": "int",
                  "required": false
                },
                "entry_flag": {
                  "type": "str",
                  "required": false
                }
              }
            }
          }
        },
        "required": true
      }
    }
  },
