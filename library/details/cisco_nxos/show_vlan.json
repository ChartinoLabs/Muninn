{
  "os": "cisco_nxos",
  "command": "show vlan",
  "schema": {
    "name": "ShowVlanResult",
    "fields": {
      "vlans": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "VlanEntry",
            "fields": {
              "vlan_id": {
                "type": "int",
                "required": true
              },
              "name": {
                "type": "str",
                "required": true
              },
              "status": {
                "type": "str",
                "required": true
              },
              "ports": {
                "type": {
                  "type": "list",
                  "items": "str"
                },
                "required": true
              },
              "type": {
                "type": "str",
                "required": true
              },
              "vlan_mode": {
                "type": "str",
                "required": true
              },
              "private_vlan": {
                "type": {
                  "name": "PrivateVlanInfo",
                  "fields": {
                    "type": {
                      "type": "str",
                      "required": true
                    },
                    "primary_vlan": {
                      "type": "str",
                      "required": false
                    },
                    "secondary_vlans": {
                      "type": {
                        "type": "list",
                        "items": "str"
                      },
                      "required": false
                    }
                  }
                },
                "required": false
              }
            }
          }
        },
        "required": true
      },
      "remote_span_vlans": {
        "type": {
          "type": "list",
          "items": "int"
        },
        "required": false
      }
    }
  },
