{
  "os": "cisco_nxos",
  "command": "show bgp l2vpn evpn summary",
  "schema": {
    "name": "ShowIpBgpSummaryResult",
    "fields": {
      "vrfs": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "VrfEntry",
            "fields": {
              "address_families": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "AddressFamilyEntry",
                    "fields": {
                      "router_id": {
                        "type": "str",
                        "required": true
                      },
                      "local_as": {
                        "type": "str",
                        "required": true
                      },
                      "table_version": {
                        "type": "int",
                        "required": true
                      },
                      "config_peers": {
                        "type": "int",
                        "required": true
                      },
                      "capable_peers": {
                        "type": "int",
                        "required": true
                      },
                      "memory": {
                        "type": {
                          "name": "MemoryInfo",
                          "fields": {
                            "network_entries": {
                              "type": "int",
                              "required": true
                            },
                            "paths": {
                              "type": "int",
                              "required": true
                            },
                            "bytes_used": {
                              "type": "int",
                              "required": true
                            },
                            "attribute_entries": {
                              "type": {
                                "name": "BracketEntries",
                                "fields": {
                                  "count": {
                                    "type": "int",
                                    "required": true
                                  },
                                  "bytes": {
                                    "type": "int",
                                    "required": true
                                  }
                                }
                              },
                              "required": true
                            },
                            "as_path_entries": {
                              "type": {
                                "type": "ref",
                                "name": "BracketEntries"
                              },
                              "required": true
                            },
                            "community_entries": {
                              "type": {
                                "type": "ref",
                                "name": "BracketEntries"
                              },
                              "required": true
                            },
                            "clusterlist_entries": {
                              "type": {
                                "type": "ref",
                                "name": "BracketEntries"
                              },
                              "required": true
                            }
                          }
                        },
                        "required": true
                      },
                      "dampening": {
                        "type": {
                          "name": "DampeningInfo",
                          "fields": {
                            "history_paths": {
                              "type": "int",
                              "required": true
                            },
                            "dampened_paths": {
                              "type": "int",
                              "required": true
                            }
                          }
                        },
                        "required": false
                      },
                      "received_paths": {
                        "type": "int",
                        "required": false
                      },
                      "neighbors": {
                        "type": {
                          "type": "dict",
                          "key": "str",
                          "value": {
                            "name": "NeighborEntry",
                            "fields": {
                              "version": {
                                "type": "int",
                                "required": true
                              },
                              "remote_as": {
                                "type": "str",
                                "required": true
                              },
                              "msg_rcvd": {
                                "type": "int",
                                "required": true
                              },
                              "msg_sent": {
                                "type": "int",
                                "required": true
                              },
                              "tbl_ver": {
                                "type": "int",
                                "required": true
                              },
                              "in_queue": {
                                "type": "int",
                                "required": true
                              },
                              "out_queue": {
                                "type": "int",
                                "required": true
                              },
                              "up_down": {
                                "type": "str",
                                "required": true
                              },
                              "state_pfxrcd": {
                                "type": "str",
                                "required": true
                              }
                            }
                          }
                        },
                        "required": true
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
