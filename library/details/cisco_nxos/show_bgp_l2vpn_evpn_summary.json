                    "count": 0
                  },
                  "community_entries": {
                    "bytes": 64,
                    "count": 2
                  },
                  "network_entries": 52,
                  "paths": 104
                },
                "neighbors": {
                  "10.1.0.2": {
                    "in_queue": 0,
                    "msg_rcvd": 524176,
                    "msg_sent": 523842,
                    "out_queue": 0,
                    "remote_as": "65000",
                    "state_pfxrcd": "26",
                    "tbl_ver": 128456,
                    "up_down": "5w2d",
                    "version": 4
                  },
                  "10.1.0.3": {
                    "in_queue": 0,
                    "msg_rcvd": 524089,
                    "msg_sent": 523790,
                    "out_queue": 0,
                    "remote_as": "65000",
                    "state_pfxrcd": "26",
                    "tbl_ver": 128456,
                    "up_down": "5w2d",
                    "version": 4
                  },
                  "10.1.0.4": {
                    "in_queue": 0,
                    "msg_rcvd": 312456,
                    "msg_sent": 298712,
                    "out_queue": 0,
                    "remote_as": "65001",
                    "state_pfxrcd": "52",
                    "tbl_ver": 128456,
                    "up_down": "3w1d",
                    "version": 4
                  },
                  "10.1.0.5": {
                    "in_queue": 0,
                    "msg_rcvd": 0,
                    "msg_sent": 0,
                    "out_queue": 0,
                    "remote_as": "65002",
                    "state_pfxrcd": "Idle",
