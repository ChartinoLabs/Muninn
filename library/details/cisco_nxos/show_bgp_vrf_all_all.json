                        "status_codes": "*>",
                        "weight": 0
                      }
                    ]
                  },
                  "192.168.1.0/24": {
                    "paths": [
                      {
                        "locprf": 100,
                        "metric": 0,
                        "next_hop": "0.0.0.0",
                        "origin": "?",
                        "path_type": "r",
                        "status_codes": "*>",
