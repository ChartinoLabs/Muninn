                        "path_type": "e",
                        "status_codes": "*>",
                        "weight": 0
                      }
                    ]
                  },
                  "10.10.0.201/32": {
                    "paths": [
                      {
                        "as_path": "64102 64201",
                        "next_hop": "10.10.2.1",
                        "origin": "i",
