                      {
                        "as_path": "64101 64201",
                        "next_hop": "10.10.1.1",
                        "origin": "i",
                        "path_type": "e",
                        "status_codes": "*",
                        "weight": 0
                      }
                    ]
                  },
                  "10.16.1.0/24": {
                    "paths": [
                      {
                        "locprf": 100,
                        "metric": 4444,
                        "next_hop": "0.0.0.0",
                        "origin": "?",
                        "path_type": "r",
                        "status_codes": "*>",
                        "weight": 32768
                      }
                    ]
                  },
                  "100.100.100.108/30": {
                    "paths": [
                      {
                        "as_path": "64102 {64201 64202}",
                        "next_hop": "10.10.2.1",
                        "origin": "i",
                        "path_type": "e",
                        "status_codes": "*>",
                        "weight": 0
                      }
                    ]
                  }
                },
                "table_version": 100
              }
            }
          }
        }
      }
