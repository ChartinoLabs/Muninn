{
  "os": "cisco_nxos",
  "command": "show ip bgp",
  "schema": {
    "name": "ShowIpBgpResult",
    "fields": {
      "vrfs": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "VrfEntry",
            "fields": {
              "address_families": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "AddressFamilyEntry",
                    "fields": {
                      "table_version": {
                        "type": "int",
                        "required": true
                      },
                      "router_id": {
                        "type": "str",
                        "required": true
                      },
                      "routes": {
                        "type": {
                          "type": "dict",
                          "key": "str",
                          "value": {
                            "name": "RouteEntry",
                            "fields": {
                              "paths": {
                                "type": {
                                  "type": "list",
                                  "items": {
                                    "name": "PathEntry",
                                    "fields": {
                                      "status_codes": {
                                        "type": "str",
                                        "required": false
                                      },
                                      "path_type": {
                                        "type": "str",
                                        "required": false
                                      },
                                      "next_hop": {
                                        "type": "str",
                                        "required": true
                                      },
                                      "metric": {
                                        "type": "int",
                                        "required": false
                                      },
                                      "locprf": {
                                        "type": "int",
                                        "required": false
                                      },
                                      "weight": {
                                        "type": "int",
                                        "required": true
                                      },
                                      "as_path": {
                                        "type": "str",
                                        "required": false
                                      },
                                      "origin": {
                                        "type": "str",
                                        "required": true
                                      }
                                    }
                                  }
                                },
                                "required": true
                              }
                            }
                          }
                        },
                        "required": false
                      },
                      "route_distinguishers": {
                        "type": {
                          "type": "dict",
                          "key": "str",
                          "value": {
                            "name": "RouteDistinguisherEntry",
                            "fields": {
                              "rd_vrf": {
                                "type": "str",
                                "required": false
                              },
                              "routes": {
                                "type": {
                                  "type": "dict",
                                  "key": "str",
                                  "value": {
                                    "type": "ref",
                                    "name": "RouteEntry"
                                  }
                                },
                                "required": true
                              }
                            }
                          }
                        },
                        "required": false
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
