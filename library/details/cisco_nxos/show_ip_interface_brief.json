                      "protocol_status": {
                        "type": "str",
                        "required": true
                      },
                      "link_status": {
                        "type": "str",
                        "required": true
                      },
                      "admin_status": {
                        "type": "str",
                        "required": true
                      },
                      "unnumbered_source": {
                        "type": "str",
                        "required": false
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
