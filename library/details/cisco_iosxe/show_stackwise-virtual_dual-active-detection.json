{
  "os": "cisco_iosxe",
  "command": "show stackwise-virtual dual-active-detection",
  "schema": {
    "name": "ShowStackwiseVirtualDualActiveDetectionResult",
    "fields": {
      "switches": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "DadPortStatus",
              "fields": {
                "status": {
                  "type": "str",
                  "required": true
                }
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
    {
      "name": "Dual-active detection ports on two switches",
      "input": "\nDual-Active-Detection Configuration:\n-------------------------------------\nSwitch  Dad port                        Status\n------  ------------                    ---------\n1       FortyGigabitEthernet1/0/3       up\n        FortyGigabitEthernet1/0/4       up\n2       FortyGigabitEthernet2/0/3       up\n        FortyGigabitEthernet2/0/4       up\n",
      "expected": {
        "switches": {
          "1": {
            "FortyGigabitEthernet1/0/3": {
              "status": "up"
            },
            "FortyGigabitEthernet1/0/4": {
              "status": "up"
            }
          },
          "2": {
            "FortyGigabitEthernet2/0/3": {
              "status": "up"
            },
            "FortyGigabitEthernet2/0/4": {
              "status": "up"
            }
          }
        }
      }
    }
  ]
}
