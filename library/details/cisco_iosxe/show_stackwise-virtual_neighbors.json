{
  "os": "cisco_iosxe",
  "command": "show stackwise-virtual neighbors",
  "schema": {
    "name": "ShowStackwiseVirtualNeighborsResult",
    "fields": {
      "switches": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "NeighborSwitchEntry",
            "fields": {
              "svl": {
                "type": "str",
                "required": true
              },
              "ports": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "NeighborPortRemote",
                    "fields": {
                      "remote_port": {
                        "type": "str",
                        "required": false
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
    {
      "name": "SVL neighbors table with continuation rows and local-only port",
      "input": "Stackwise Virtual Link(SVL) Neighbors Information:\n--------------------------------------------------\nSwitch  SVL     Local Port                         Remote Port\n------  ---     ----------                         -----------\n1       1       HundredGigE1/1/0/19                HundredGigE2/1/0/23\n                HundredGigE1/5/0/17                HundredGigE2/1/0/24\n                FiftyGigE1/6/0/33\n2       1       HundredGigE2/1/0/23                HundredGigE1/1/0/19\n                HundredGigE2/1/0/24                HundredGigE1/5/0/17\n                FiftyGigE2/6/0/29\n",
      "expected": {
        "switches": {
          "1": {
            "ports": {
              "FiftyGigabitEthernet1/6/0/33": {},
              "HundredGigabitEthernet1/1/0/19": {
                "remote_port": "HundredGigabitEthernet2/1/0/23"
              },
              "HundredGigabitEthernet1/5/0/17": {
                "remote_port": "HundredGigabitEthernet2/1/0/24"
              }
            },
            "svl": "1"
          },
          "2": {
            "ports": {
              "FiftyGigabitEthernet2/6/0/29": {},
              "HundredGigabitEthernet2/1/0/23": {
                "remote_port": "HundredGigabitEthernet1/1/0/19"
              },
              "HundredGigabitEthernet2/1/0/24": {
                "remote_port": "HundredGigabitEthernet1/5/0/17"
              }
            },
            "svl": "1"
          }
        }
      }
    }
  ]
}
