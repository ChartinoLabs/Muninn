                        "type": "str",
                        "required": false
                      },
                      "pfx_count": {
                        "type": "int",
                        "required": false
                      },
                      "pfx_limit": {
                        "type": "int",
                        "required": false
                      },
                      "routes": {
                        "type": {
                          "type": "dict",
                          "key": "str",
                          "value": {
                            "name": "RouteEntry",
                            "fields": {
                              "paths": {
                                "type": {
                                  "type": "list",
                                  "items": {
                                    "name": "PathEntry",
                                    "fields": {
                                      "status_codes": {
                                        "type": "str",
                                        "required": true
                                      },
                                      "path_type": {
                                        "type": "str",
                                        "required": false
                                      },
                                      "next_hop": {
                                        "type": "str",
                                        "required": true
                                      },
                                      "metric": {
                                        "type": "int",
                                        "required": false
                                      },
                                      "locprf": {
                                        "type": "int",
                                        "required": false
                                      },
                                      "weight": {
                                        "type": "int",
                                        "required": true
                                      },
                                      "as_path": {
                                        "type": "str",
                                        "required": false
                                      },
                                      "origin": {
                                        "type": "str",
                                        "required": true
                                      }
                                    }
                                  }
                                },
                                "required": true
                              }
                            }
                          }
                        },
                        "required": true
                      }
                    }
                  }
                },
                "required": false
              },
              "routes": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "type": "ref",
                    "name": "RouteEntry"
                  }
                },
                "required": false
              }
            }
          }
        },
        "required": true
