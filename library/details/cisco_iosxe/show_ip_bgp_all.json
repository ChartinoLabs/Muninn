{
  "os": "cisco_iosxe",
  "command": "show ip bgp all",
  "schema": {
    "name": "ShowBgpAllResult",
    "fields": {
      "address_families": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "AddressFamilyEntry",
