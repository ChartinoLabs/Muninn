      "input": "Total number of groups:   112\n",
      "expected": {
        "total_number_of_groups": {
          "igmp_groups_count": 112
        }
      }
    },
    {
      "name": "Live device output",
      "input": "Total number of groups:   0\nTotal number of  (S,G):   0\n",
      "expected": {
        "total_number_of_groups": {
          "igmp_groups_count": 0
        }
      }
