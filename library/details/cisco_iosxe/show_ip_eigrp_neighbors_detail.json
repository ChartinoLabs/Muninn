{
  "os": "cisco_iosxe",
  "command": "show ip eigrp neighbors detail",
  "schema": {
    "name": "ShowIpEigrpNeighborsDetailResult",
    "fields": {
      "neighbors": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "EigrpDetailNeighborEntry",
              "fields": {
                "handle": {
                  "type": "int",
                  "required": true
                },
                "hold_time": {
                  "type": "int",
                  "required": true
                },
                "uptime": {
                  "type": "str",
                  "required": true
                },
                "srtt": {
                  "type": "int",
                  "required": true
                },
                "rto": {
                  "type": "int",
                  "required": true
                },
                "queue_count": {
                  "type": "int",
                  "required": true
                },
                "sequence_number": {
                  "type": "int",
                  "required": true
                },
                "software_version": {
                  "type": "str",
                  "required": true
                },
                "retransmit_count": {
                  "type": "int",
                  "required": true
                },
                "retry_count": {
                  "type": "int",
                  "required": true
                },
                "prefixes": {
                  "type": "int",
                  "required": false
                },
                "topology_ids_from_peer": {
                  "type": "int",
                  "required": true
                },
                "topology_advert_to_peer": {
                  "type": "str",
                  "required": false
                }
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
    {
