                      {
                        "expiration": 2.985
                      }
                    ]
                  }
                }
              },
              "sia": {
                "timers": {
                  "parent": {
                    "entries": [
                      {
                        "expiration": 0.0
                      }
                    ]
                  }
                }
              },
              "update": {
                "timers": {
                  "parent": {
                    "entries": [
                      {
                        "expiration": 13.19
                      },
                      {
                        "expiration": 13.19
                      }
                    ]
                  },
                  "peer_holding": {
                    "entries": [
                      {
                        "expiration": 13.19
                      }
                    ]
