{
  "os": "cisco_iosxe",
  "command": "show bgp all",
  "schema": {
    "name": "ShowBgpAllResult",
    "fields": {
      "address_families": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "AddressFamilyEntry",
            "fields": {
              "table_version": {
                "type": "int",
                "required": false
              },
              "router_id": {
                "type": "str",
                "required": false
              },
              "route_distinguishers": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "RdEntry",
                    "fields": {
                      "rd": {
                        "type": "str",
                        "required": true
                      },
                      "default_vrf": {
                        "type": "str",
                        "required": false
                      },
                      "vrf_router_id": {
                        "type": "str",
                        "required": false
                      },
                      "af_private_import_to_af": {
                        "type": "str",
                        "required": false
                      },
                      "pfx_count": {
                        "type": "int",
                        "required": false
                      },
                      "pfx_limit": {
                        "type": "int",
                        "required": false
                      },
                      "routes": {
                        "type": {
                          "type": "dict",
                          "key": "str",
                          "value": {
                            "name": "RouteEntry",
                            "fields": {
                              "paths": {
                                "type": {
                                  "type": "list",
                                  "items": {
                                    "name": "PathEntry",
                                    "fields": {
                                      "status_codes": {
                                        "type": "str",
                                        "required": true
                                      },
                                      "path_type": {
                                        "type": "str",
                                        "required": true
                                      },
                                      "next_hop": {
                                        "type": "str",
                                        "required": true
                                      },
                                      "metric": {
                                        "type": "int",
                                        "required": false
                                      },
                                      "locprf": {
                                        "type": "int",
                                        "required": false
                                      },
                                      "weight": {
                                        "type": "int",
                                        "required": true
                                      },
                                      "as_path": {
                                        "type": "str",
                                        "required": true
                                      },
                                      "origin": {
                                        "type": "str",
                                        "required": true
                                      }
                                    }
                                  }
                                },
                                "required": true
                              }
                            }
                          }
                        },
                        "required": true
                      }
                    }
                  }
                },
                "required": false
              },
              "routes": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "type": "ref",
                    "name": "RouteEntry"
                  }
                },
                "required": false
              }
            }
          }
        },
        "required": true
      }
    }
