{
  "os": "cisco_iosxe",
  "command": "show ip ospf neighbor",
  "schema": {
    "name": "ShowIpOspfNeighborResult",
    "fields": {
      "neighbors": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "OspfNeighborEntry",
              "fields": {
                "priority": {
                  "type": "int",
                  "required": true
                },
                "state": {
                  "type": "str",
                  "required": true
                },
                "dead_time": {
                  "type": "str",
                  "required": true
                },
                "address": {
                  "type": "str",
                  "required": true
                },
                "role": {
                  "type": "str",
                  "required": false
                }
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
