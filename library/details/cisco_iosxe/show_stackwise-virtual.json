{
  "os": "cisco_iosxe",
  "command": "show stackwise-virtual",
  "schema": {
    "name": "ShowStackwiseVirtualResult",
    "fields": {
      "stackwise_virtual": {
        "type": "str",
        "required": true
      },
      "domain_number": {
        "type": "int",
        "required": true
      },
      "switches": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "SwitchEntry",
            "fields": {
              "links": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "SVLLink",
                    "fields": {
                      "ports": {
                        "type": {
                          "type": "list",
                          "items": "str"
                        },
                        "required": true
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": false
      }
    }
  },
  "examples": [
    {
      "name": "Two-switch StackWise Virtual with single SVL link per switch",
      "input": "Stackwise Virtual Configuration:\n--------------------------------\nStackwise Virtual : Enabled\nDomain Number : 10\n\nSwitch  Stackwise Virtual Link  Ports\n------  ----------------------  ------\n1       1                       HundredGigE1/0/51\n                                HundredGigE1/0/52\n2       1                       HundredGigE2/0/51\n                                HundredGigE2/0/52\n",
      "expected": {
        "domain_number": 10,
        "stackwise_virtual": "Enabled",
        "switches": {
          "1": {
            "links": {
              "1": {
                "ports": [
                  "HundredGigabitEthernet1/0/51",
                  "HundredGigabitEthernet1/0/52"
                ]
              }
            }
          },
          "2": {
            "links": {
              "1": {
                "ports": [
                  "HundredGigabitEthernet2/0/51",
                  "HundredGigabitEthernet2/0/52"
                ]
              }
            }
          }
        }
      }
    }
  ]
}
