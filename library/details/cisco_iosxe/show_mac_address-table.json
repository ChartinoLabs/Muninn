            },
            "cc98.91ff.e97e": {
              "kind": "unicast",
              "type": "dynamic",
              "ports": [
                "GigabitEthernet1/0/28"
              ]
            },
            "cc98.91ff.09b8": {
              "kind": "unicast",
              "type": "dynamic",
              "ports": [
                "GigabitEthernet1/0/34"
              ]
