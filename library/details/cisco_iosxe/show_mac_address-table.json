{
  "os": "cisco_iosxe",
  "command": "show mac address-table",
  "schema": {
    "name": "ShowMacAddressTableResult",
    "fields": {
      "mac_table": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "MacTableRow",
              "fields": {
                "kind": {
                  "type": {
                    "type": "literal",
                    "values": [
                      "unicast",
                      "multicast"
                    ]
                  },
                  "required": false
                },
                "type": {
                  "type": "str",
                  "required": false
                },
                "ports": {
                  "type": {
                    "type": "list",
                    "items": "str"
                  },
                  "required": false
                },
                "primary": {
                  "type": "bool",
                  "required": false
                },
                "age": {
                  "type": "int",
                  "required": false
                },
                "learn": {
                  "type": "bool",
                  "required": false
                },
                "protocols": {
                  "type": {
                    "type": "list",
                    "items": "str"
                  },
                  "required": false
                }
              }
            }
          }
        },
        "required": false
      },
      "total_mac_addresses": {
        "type": "int",
        "required": false
      }
    }
  },
  "examples": [
    {
      "name": "Basic MAC address table filtered by VLAN with static and dynamic entries",
      "input": "show mac address-table vlan 101\n\n            Mac Address Table\n-------------------------------------------\n\nVlan    Mac Address       Type        Ports\n----    -----------       --------    -----\n101    701f.53ff.4de2    STATIC      Gi2/0/30\n101    cc5a.53ff.acc7    STATIC      Vl101\n101    cc98.91ff.cbc2    DYNAMIC     Gi1/0/32\n101    cc98.91ff.e84f    DYNAMIC     Gi1/0/31\n101    cc98.91ff.e97e    DYNAMIC     Gi1/0/28\n101    cc98.91ff.09b8    DYNAMIC     Gi1/0/34\n101    cc98.91ff.0cc4    DYNAMIC     Gi1/0/33\n101    cc98.91ff.0d94    DYNAMIC     Gi1/0/29\nTotal Mac Addresses for this criterion: 8\n",
      "expected": {
        "mac_table": {
          "101": {
            "701f.53ff.4de2": {
              "kind": "unicast",
              "type": "static",
              "ports": [
                "GigabitEthernet2/0/30"
              ]
            },
            "cc5a.53ff.acc7": {
              "kind": "unicast",
              "type": "static",
              "ports": [
                "VLAN101"
              ]
