{
  "os": "cisco_iosxe",
  "command": "show vpdn",
  "schema": {
    "name": "ShowVpdnResult",
    "fields": {
      "total_tunnels": {
        "type": "int",
        "required": false
      },
      "total_sessions": {
        "type": "int",
        "required": false
      },
      "tunnels": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "VpdnTunnelEntry",
            "fields": {
              "local_tunnel_id": {
                "type": "int",
                "required": true
              },
              "remote_tunnel_id": {
                "type": "int",
                "required": true
              },
              "remote_name": {
                "type": "str",
                "required": true
              },
              "state": {
                "type": "str",
                "required": true
              },
              "remote_address": {
                "type": "str",
                "required": true
              },
              "session_count": {
                "type": "int",
                "required": true
              },
              "vpdn_group": {
                "type": "str",
                "required": true
              }
            }
          }
        },
        "required": false
      },
      "sessions": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "VpdnSessionEntry",
            "fields": {
              "local_id": {
                "type": "int",
                "required": true
              },
              "remote_id": {
                "type": "int",
                "required": true
              },
              "tunnel_id": {
                "type": "int",
                "required": true
              },
              "username": {
                "type": "str",
                "required": true
              },
              "interface": {
                "type": "str",
                "required": false
              },
              "state": {
                "type": "str",
                "required": true
              },
              "last_change": {
                "type": "str",
                "required": true
              },
              "unique_id": {
                "type": "int",
                "required": true
              }
            }
          }
        },
        "required": false
      }
    }
  },
  "examples": [
