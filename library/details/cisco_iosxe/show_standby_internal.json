{
  "os": "cisco_iosxe",
  "command": "show standby internal",
  "schema": {
    "name": "ShowStandbyInternalResult",
    "fields": {
      "hsrp_common_process_state": {
        "type": "str",
        "required": true
      },
      "msgq_size": {
        "type": "int",
        "required": true
      },
      "msgq_max_size": {
        "type": "int",
        "required": true
      },
      "hsrp_ipv4_process_state": {
        "type": "str",
        "required": true
      },
      "hsrp_ipv6_process_state": {
        "type": "str",
        "required": true
      },
      "hsrp_timer_wheel_state": {
        "type": "str",
        "required": true
      },
      "hsrp_ha_state": {
        "type": "str",
        "required": true
      },
      "v3_to_v4_transform": {
        "type": "str",
        "required": true
      },
      "virtual_ip_hash_table": {
        "type": {
          "name": "VirtualIpHashTable",
          "fields": {
            "ipv4": {
              "type": {
                "type": "dict",
                "key": "str",
                "value": {
                  "name": "VirtualIpEntry",
                  "fields": {
                    "ip": {
                      "type": "str",
                      "required": true
                    },
                    "interface": {
                      "type": "str",
                      "required": true
                    },
                    "group": {
                      "type": "int",
                      "required": true
                    }
                  }
                }
              },
              "required": false
            },
            "ipv6": {
              "type": {
                "type": "dict",
                "key": "str",
                "value": {
                  "type": "ref",
                  "name": "VirtualIpEntry"
                }
              },
              "required": false
            }
          }
        },
        "required": false
      },
      "mac_address_table": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "MacAddressEntry",
            "fields": {
              "interface": {
                "type": "str",
                "required": true
              },
              "mac_address": {
                "type": "str",
                "required": true
              },
              "group": {
                "type": "int",
                "required": true
              }
            }
          }
        },
        "required": false
      }
    }
  },
  "examples": [
