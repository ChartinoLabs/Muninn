            "mac_address": "0000.0cff.b30c"
          },
          "172": {
            "group": 0,
            "interface": "GigabitEthernet2/0/3",
            "mac_address": "0000.0cff.b307"
          },
          "173": {
            "group": 1,
            "interface": "GigabitEthernet2/0/3",
            "mac_address": "0000.0cff.b308"
          }
        },
        "msgq_max_size": 0,
        "msgq_size": 0,
        "v3_to_v4_transform": "disabled",
        "virtual_ip_hash_table": {
          "ipv4": {
            "103": {
              "group": 0,
              "interface": "GigabitEthernet1/0/1",
