      "expected": {
        "hsrp_common_process_state": "running",
        "hsrp_ha_state": "capable",
        "hsrp_ipv4_process_state": "running",
        "hsrp_ipv6_process_state": "running",
        "hsrp_timer_wheel_state": "running",
        "msgq_max_size": 128,
        "msgq_size": 5,
        "v3_to_v4_transform": "enabled"
