    {
      "name": "Live device output",
      "input": "HSRP common process not running\nHSRP IPv4 process not running\nHSRP IPv6 process not running\nHSRP Timer wheel running\nHSRP HA capable, v3 to v4 transform disabled\n\nGlobal           Confg: 0000\n\nHSRP MAC Address Table\n",
      "expected": {
        "hsrp_common_process_state": "not running",
        "hsrp_ipv4_process_state": "not running",
        "hsrp_ipv6_process_state": "not running",
        "hsrp_timer_wheel_state": "running",
        "hsrp_ha_state": "capable",
        "v3_to_v4_transform": "disabled"
