{
  "os": "cisco_iosxe",
  "command": "show switch",
  "schema": {
    "name": "ShowSwitchResult",
    "fields": {
      "stack_mac_address": {
        "type": "str",
        "required": true
      },
      "switches": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "SwitchEntry",
            "fields": {
              "role": {
                "type": "str",
                "required": true
              },
              "mac_address": {
                "type": "str",
                "required": true
              },
              "priority": {
                "type": "int",
                "required": true
              },
              "state": {
                "type": "str",
                "required": true
              },
              "is_active": {
                "type": "bool",
                "required": true
              },
              "hw_version": {
                "type": "str",
                "required": false
              }
            }
          }
        },
        "required": true
      },
      "mac_persistency_wait_time": {
        "type": "str",
        "required": false
      }
    }
  },
  "examples": [
    {
      "name": "Four-member stack with Active, Standby, Member roles and V-Mismatch state",
      "input": "Switch/Stack Mac Address : 689c.e2ff.b9d9 - Local Mac Address\nMac persistency wait time: Indefinite\n                                             H/W   Current\nSwitch#   Role    Mac Address     Priority Version  State\n-------------------------------------------------------------------------------------\n*1       Active   689c.e2ff.b9d9     3      V04     Ready\n 2       Standby  c800.84ff.7e00     2      V05     Ready\n 3       Member   c800.84ff.4800     1      V05     Ready\n 4       Member   00cc.fcff.7b00     15     0       V-Mismatch\n",
      "expected": {
        "mac_persistency_wait_time": "Indefinite",
        "stack_mac_address": "689c.e2ff.b9d9",
        "switches": {
          "1": {
            "hw_version": "V04",
            "is_active": true,
            "mac_address": "689c.e2ff.b9d9",
            "priority": 3,
            "role": "Active",
            "state": "Ready"
          },
          "2": {
            "hw_version": "V05",
            "is_active": false,
            "mac_address": "c800.84ff.7e00",
            "priority": 2,
            "role": "Standby",
            "state": "Ready"
          },
          "3": {
            "hw_version": "V05",
            "is_active": false,
            "mac_address": "c800.84ff.4800",
            "priority": 1,
            "role": "Member",
            "state": "Ready"
          },
          "4": {
            "hw_version": "0",
            "is_active": false,
            "mac_address": "00cc.fcff.7b00",
            "priority": 15,
            "role": "Member",
            "state": "V-Mismatch"
          }
        }
      }
    },
    {
      "name": "Three-member stack with provisioned members missing hardware version",
      "input": "Switch/Stack Mac Address : 0c75.bd6e.db00 - Local Mac Address\nMac persistency wait time: Indefinite\n                                             H/W   Current\nSwitch#   Role    Mac Address     Priority Version  State\n-------------------------------------------------------------------------------------\n*1       Active   0c75.bd6e.db00     15     V02     Ready\n 2       Member   0000.0000.0000     0              Provisioned\n 3       Member   0000.0000.0000     0              Provisioned\n",
      "expected": {
        "mac_persistency_wait_time": "Indefinite",
        "stack_mac_address": "0c75.bd6e.db00",
        "switches": {
          "1": {
            "hw_version": "V02",
            "is_active": true,
            "mac_address": "0c75.bd6e.db00",
            "priority": 15,
            "role": "Active",
            "state": "Ready"
          },
          "2": {
            "is_active": false,
            "mac_address": "0000.0000.0000",
            "priority": 0,
            "role": "Member",
            "state": "Provisioned"
          },
          "3": {
            "is_active": false,
            "mac_address": "0000.0000.0000",
            "priority": 0,
            "role": "Member",
            "state": "Provisioned"
          }
        }
      }
    }
  ]
}
