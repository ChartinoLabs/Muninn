                        "required": true
                      },
                      "master_address": {
                        "type": "str",
                        "required": true
                      },
                      "group_address": {
                        "type": "str",
                        "required": true
                      },
                      "address_family": {
                        "type": "str",
                        "required": false
                      }
                    }
                  }
                },
                "required": true
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
