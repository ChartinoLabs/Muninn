{
  "os": "cisco_iosxe",
  "command": "show vrrp brief",
  "schema": {
    "name": "ShowVrrpBriefResult",
    "fields": {
      "interfaces": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "name": "VrrpInterfaceEntry",
            "fields": {
              "groups": {
                "type": {
                  "type": "dict",
                  "key": "str",
                  "value": {
                    "name": "VrrpBriefEntry",
                    "fields": {
                      "group": {
                        "type": "int",
                        "required": true
