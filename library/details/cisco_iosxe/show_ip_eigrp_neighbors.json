{
  "os": "cisco_iosxe",
  "command": "show ip eigrp neighbors",
  "schema": {
    "name": "ShowIpEigrpNeighborsResult",
    "fields": {
      "neighbors": {
        "type": {
          "type": "dict",
          "key": "str",
          "value": {
            "type": "dict",
            "key": "str",
            "value": {
              "name": "EigrpNeighborEntry",
              "fields": {
                "handle": {
                  "type": "int",
                  "required": true
                },
                "hold_time": {
                  "type": "int",
                  "required": true
                },
                "uptime": {
                  "type": "str",
                  "required": true
                },
                "srtt": {
                  "type": "int",
                  "required": true
                },
                "rto": {
                  "type": "int",
                  "required": true
                },
                "queue_count": {
                  "type": "int",
                  "required": true
                },
                "sequence_number": {
                  "type": "int",
                  "required": true
                }
              }
            }
          }
        },
        "required": true
      }
    }
  },
  "examples": [
    {
      "name": "Single EIGRP neighbor on one interface",
      "input": "\nDevice# show ip eigrp neighbors\nH   Address      Interface  Hold  Uptime    SRTT   RTO    Q   Seq\n                            (sec)           (ms)          Cnt Num\n0   10.1.1.2     Gi0/0      13    00:00:03  1996   5000   0   5\n",
      "expected": {
        "neighbors": {
          "GigabitEthernet0/0": {
            "10.1.1.2": {
              "handle": 0,
              "hold_time": 13,
              "queue_count": 0,
              "rto": 5000,
              "sequence_number": 5,
              "srtt": 1996,
              "uptime": "00:00:03"
            }
          }
        }
      }
    },
    {
